# =============================================================================
# LOF Hacker 配置文件
# =============================================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入你的真实配置
# 3. 切勿将 .env 文件提交到 Git
# =============================================================================

# -----------------------------------------------------------------------------
# 集思录登录配置
# -----------------------------------------------------------------------------
# 认证方式 1：Cookie 文件（推荐）
# 从浏览器开发者工具中导出完整的 cookies
# 获取方法：
#   1. 登录集思录 https://www.jisilu.cn
#   2. 按 F12 打开开发者工具
#   3. 在 Console 中执行：
#      copy(JSON.stringify(document.cookie.split('; ').map(c => {
#          const [name, value] = c.split('=');
#          return {name, value, domain: '.jisilu.cn', path: '/'};
#      }), null, 2));
#   4. 将复制的 JSON 保存为项目根目录的 .jisilu_cookies.json 文件
#
# 注意：必须使用完整的 cookie 文件，单独设置 Session ID 是无效的

# 认证方式 2：加密后的用户名和密码（备用，无需定期更新 cookie）
# 获取方法：
#   1. 在浏览器中登录集思录
#   2. 按 F12 打开开发者工具，切换到 Network 标签
#   3. 重新登录一次，找到 login_process 请求
#   4. 查看请求的 Payload/Request 参数
#   5. 复制 user_name 和 password 的值（已加密）
#   6. 填入下面的配置项
JISILU_ENCRYPTED_USERNAME=
JISILU_ENCRYPTED_PASSWORD=

# -----------------------------------------------------------------------------
# 邮件通知配置（126 邮箱）
# -----------------------------------------------------------------------------
EMAIL_SMTP_SERVER=smtp.126.com
EMAIL_SMTP_PORT=465
EMAIL_USERNAME=your_email@126.com
EMAIL_PASSWORD=your_email_auth_code
EMAIL_RECIPIENT=recipient@example.com

# -----------------------------------------------------------------------------
# 飞书通知配置（可选）
# -----------------------------------------------------------------------------
# 启用飞书通知：true 或 false
FEISHU_ENABLED=false

# 飞书机器人 Webhook URL
# 获取方法：在飞书群聊中添加"自定义机器人" → 复制 Webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token

# 消息类型：interactive（交互式卡片）或 text（纯文本）
# 注意：自定义机器人可能只支持 text 格式，如 interactive 无法显示内容，请改为 text
FEISHU_MESSAGE_TYPE=text

# 飞书消息显示字段配置
# 必选字段（始终显示）：code, name, premium_rate, subscription_status
NOTIFY_REQUIRED_FIELDS=code,name,premium_rate,subscription_status

# 可选字段（逗号分隔）：
#   - price: 现价
#   - estimate_value: 估值
#   - fund_nav: 净值
#   - nav_dt: 净值日期
#   - volume: 成交额
#   - turnover_rt: 换手率
NOTIFY_OPTIONAL_FIELDS=

# -----------------------------------------------------------------------------
# 套利筛选条件（统一使用 FILTER_ 前缀）
# -----------------------------------------------------------------------------
# 溢价率阈值（%）- 只提醒溢价率大于此值的基金
FILTER_PREMIUM_THRESHOLD=0.5

# 最小成交额（万元）- 避免流动性不足
FILTER_MIN_VOLUME=100

# LOF 申购状态 API 参数配置
# 通过 API 请求参数 cnd 控制获取哪些申购状态的基金
# 可选值：LMT (限额), STP (暂停申购), OPN (开放申购), ALL (全部)
# 支持多个值，逗号分隔，例如：FILTER_CND_STATUS=LMT,STP
# 默认只获取限额状态的基金
FILTER_CND_STATUS=LMT

# 注意：申购状态（apply_status）仅用于展示，不再作为筛选条件
# API 会根据 FILTER_CND_STATUS 参数返回对应状态的基金数据

# -----------------------------------------------------------------------------
# 通知字段配置
# -----------------------------------------------------------------------------
# 必选字段（始终显示）
NOTIFY_REQUIRED_FIELDS=code,name,premium_rate,subscription_status

# 可选字段（自定义）
# 可选：current_price,estimated_value,volume,apply_fee,redeem_fee,nav,turnover_rate
NOTIFY_OPTIONAL_FIELDS=

# -----------------------------------------------------------------------------
# 定时任务配置（Cron 表达式）
# -----------------------------------------------------------------------------
# 格式：分钟 小时 日 月 星期
# 示例：
#   每天 13:00     -> 0 13 * * *
#   每天 9:00,13:00 -> 0 9,13 * * *
#   交易日每 30 分钟  -> */30 9-15 * * 1-5
SCHEDULE_CRON=0 13 * * *

# 时区配置
SCHEDULE_TIMEZONE=Asia/Shanghai

# -----------------------------------------------------------------------------
# 黑白名单配置（可选）
# -----------------------------------------------------------------------------
# 黑名单 - 永不提醒的基金代码，逗号分隔
FILTER_BLACKLIST=

# 白名单 - 只提醒这些基金，逗号分隔（留空则不使用白名单）
FILTER_WHITELIST=

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
